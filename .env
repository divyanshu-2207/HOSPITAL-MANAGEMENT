# ═══════════════════════════════════════════
# MEDICARE HOSPITAL — .env
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════
 
PORT=5000
NODE_ENV=development
 
# JWT Secret — change this to a strong random string in production!
JWT_SECRET=medicare_super_secret_jwt_key_2024_change_this
 
# JWT expiry
JWT_EXPIRES_IN=7d
 
# Database path (SQLite)
DB_PATH=./hospital.db
 
# CORS — add your frontend URL here
FRONTEND_URL=http://localhost:3000
 
# Email (optional — for appointment confirmations)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your@gmail.com
# EMAIL_PASS=yourapppassword
